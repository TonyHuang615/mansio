[Unit]
Description=Mansio - Web-based Multi-Terminal Server
After=network.target

[Service]
Type=simple
User=%i
ExecStart=/usr/local/bin/mansio --host 127.0.0.1 --port 8080 --data-dir /var/lib/mansio
Restart=on-failure
RestartSec=5
Environment=HOME=%h
WorkingDirectory=%h

[Install]
WantedBy=multi-user.target
